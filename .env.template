# Withings Developer App — https://developer.withings.com/dashboard/
WITHINGS_CLIENT_ID=
WITHINGS_CONSUMER_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:8765/callback

# Telegram User-API (MTProto), Credentials von https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+49...

# Ziel: Username des fremden Bots (mit @ oder ohne) oder numerische Chat-ID
